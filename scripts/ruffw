#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
REPO_ROOT=$(cd -- "${SCRIPT_DIR}/.." && pwd)
PYTHON_BIN=${PYTHON_BIN:-python3}
RUFF_VERSION=${RUFF_VERSION:-0.11.8}
RUFF_HOME="${REPO_ROOT}/.tools/ruff/${RUFF_VERSION}"

if ! command -v "${PYTHON_BIN}" >/dev/null 2>&1; then
  echo "error: ${PYTHON_BIN} is required to bootstrap ruff" >&2
  exit 1
fi

ruff_installed() {
  PYTHONPATH="${RUFF_HOME}${PYTHONPATH:+:${PYTHONPATH}}" "${PYTHON_BIN}" - <<'PY' >/dev/null 2>&1
import importlib.metadata
import os
import sys
expected = os.environ["RUFF_VERSION"]
try:
    actual = importlib.metadata.version("ruff")
except importlib.metadata.PackageNotFoundError:
    sys.exit(1)
sys.exit(0 if actual == expected else 1)
PY
}

if ! RUFF_VERSION="${RUFF_VERSION}" ruff_installed; then
  rm -rf "${RUFF_HOME}"
  mkdir -p "${RUFF_HOME}"
  "${PYTHON_BIN}" -m pip install \
    --disable-pip-version-check \
    --no-compile \
    --no-warn-script-location \
    --target "${RUFF_HOME}" \
    "ruff==${RUFF_VERSION}" >/dev/null
fi

exec env PYTHONPATH="${RUFF_HOME}${PYTHONPATH:+:${PYTHONPATH}}" "${PYTHON_BIN}" -m ruff "$@"
